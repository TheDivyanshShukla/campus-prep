SECRET_KEY=your-secret-key-here
BIFROST_API_KEY=your-bifrost-api-key

# Razorpay Test Keys
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# AI Parser Settings
AI_PARSER_RETRIES=100
AI_PARSER_CHUNK_SIZE=10
AI_PARSER_MAX_CONCURRENCY=30
AI_PARSER_OVERLAP_SIZE=1

DEBUG=True
ENABLE_SILK=False
SILKY_INTERCEPT_PERCENT=100
SILKY_PYTHON_PROFILER=False

CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key

USE_S3=True
B2_ACCESS_KEY_ID=your-b2-access-key-id
B2_SECRET_ACCESS_KEY=your-b2-secret-access-key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_DIRECT_DELIVERY=True

DJANGO_SUPERUSER_USERNAME=your-superuser-username
DJANGO_SUPERUSER_PASSWORD=your-superuser-password

CF_AUTH_TOKEN=your-cloudflare-auth-token
CF_ZONE_ID=your-cloudflare-zone-id

DATABASE_URL=sqlite:///data/db.sqlite3

EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email-host-user
EMAIL_HOST_PASSWORD=your-email-host-password
DEFAULT_FROM_EMAIL=noreply@campusprep.in

GOOGLE_CLIENT_JSON=your-google-client-json

# Cloudflare Turnstile Keys - Get from https://dash.cloudflare.com/
# Keep your SECRET_KEY private and never commit to version control
CLOUDFLARE_TURNSTILE_SITE_KEY=your-turnstile-site-key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your-turnstile-secret-key
